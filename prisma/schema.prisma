generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String                  @id @default(cuid())
  email              String                  @unique
  name               String?
  image              String?
  emailVerified      DateTime?
  credits            Int                     @default(40)
  role               Role                    @default(USER)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  password           String?
  creditsExpiresAt   DateTime?
  accounts           Account[]
  autoChannels       AutoChannel[]
  autoPosts          AutoPost[]
  avatarVideos       AvatarVideo[]
  creditBalance      CreditBalance?
  purchaseHistory    CreditPurchaseHistory[]
  creditTransactions CreditTransaction[]
  faceSwapJobs       FaceSwapJob[]
  generations        Generation[]
  imageUpscales      ImageUpscale[]
  sessions           Session[]
  supportMessages    SupportMessage[]
  transactions       Transaction[]
  apiConfig          UserApiConfig?
  userAvatars        UserAvatar[]
  subscription       UserSubscription?
  userSessions       UserSession[]
}

model UserApiConfig {
  id            String   @id @default(cuid())
  userId        String   @unique
  openaiKey     String?
  replicateKey  String?
  elevenlabsKey String?
  heygenKey     String?
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FaceSwapJob {
  id           String   @id @default(cuid())
  userId       String
  jobId        String?
  status       String   @default("PENDING")
  sourceImage  String
  targetImage  String
  resultImage  String?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupportMessage {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String
  whatsapp  String
  message   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PhotoModel {
  id              String       @id @default(cuid())
  name            String
  description     String
  category        String       @default("geral")
  thumbnailUrl    String
  promptTemplate  String
  isPremium       Boolean      @default(false)
  creditsRequired Int          @default(1)
  isActive        Boolean      @default(true)
  displayOrder    Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  generations     Generation[]
  tags            Tag[]        @relation("PhotoModelTags")
}

model Tag {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  color       String       @default("#6366f1")
  createdAt   DateTime     @default(now())
  photoModels PhotoModel[] @relation("PhotoModelTags")
}

model Generation {
  id          String     @id @default(cuid())
  userId      String
  modelId     String
  aspectRatio String
  resultUrl   String?
  status      Status     @default(PENDING)
  createdAt   DateTime   @default(now())
  model       PhotoModel @relation(fields: [modelId], references: [id])
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  stripeId  String   @unique
  packageId String
  amount    Float
  credits   Int
  status    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ImageUpscale {
  id           String   @id @default(cuid())
  userId       String
  imageUrl     String
  scale        String
  resultUrl    String?
  status       String   @default("pending")
  creditsUsed  Int
  runpodJobId  String?
  createdAt    DateTime @default(now())
  errorMessage String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditBalance {
  id           String   @id @default(cuid())
  userId       String   @unique
  totalCredits Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id          String    @id @default(cuid())
  userId      String
  type        String
  amount      Int
  source      String?
  featureUsed String?
  expiresAt   DateTime?
  status      String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([expiresAt])
}

model UserSubscription {
  id                String    @id @default(cuid())
  userId            String    @unique
  planType          String
  isActive          Boolean   @default(true)
  stripePriceId     String?
  currentPeriodEnd  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  cancelAtPeriodEnd Boolean   @default(false)
  stripeCustomerId  String?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditPurchaseHistory {
  id              String   @id @default(cuid())
  userId          String
  amount          Float
  createdAt       DateTime @default(now())
  creditsGranted  Int
  planType        String?
  status          String
  stripePaymentId String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  deviceInfo String?  @map("device_info")
  ipAddress  String?  @map("ip_address")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ap_user_sessions")
}

model AutoChannel {
  id                String      @id @default(cuid())
  userId            String
  name              String
  slug              String      @unique
  description       String?
  type              ChannelType
  platform          Platform
  language          String
  voiceId           String?
  avatarConfig      Json?
  visualStylePrompt String?
  musicFolderId     String?
  qtdImages         Int         @default(5)
  googleDriveFolder String?
  googleSpreadsheet String?
  youtubeChannelId  String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  isAutonomous      Boolean     @default(false)
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  postsPerDay       Int         @default(1)
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts             AutoPost[]
  topics            Topic[]

  @@index([userId])
  @@index([slug])
}

model Topic {
  id           String      @id @default(cuid())
  channelId    String
  title        String
  description  String?
  keywords     String[]
  status       TopicStatus @default(PENDING)
  priority     Int         @default(0)
  createdAt    DateTime    @default(now())
  scheduledFor DateTime?
  post         AutoPost?
  channel      AutoChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@index([status])
  @@index([priority])
}

model AutoPost {
  id             String      @id @default(cuid())
  userId         String
  channelId      String
  topicId        String?     @unique
  title          String
  description    String?
  tags           String[]
  thumbnailUrl   String?
  scriptContent  String?
  videoUrl       String?
  duration       Int?
  status         PostStatus  @default(DRAFT)
  currentStep    String?
  errorMessage   String?
  n8nExecutionId String?
  workflowData   Json?
  createdAt      DateTime    @default(now())
  processedAt    DateTime?
  publishedAt    DateTime?
  channel        AutoChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  topic          Topic?      @relation(fields: [topicId], references: [id])
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([channelId])
  @@index([status])
  @@index([createdAt])
}

model AvatarVideo {
  id           String      @id @default(cuid())
  userId       String
  inputText    String
  imageUrl     String
  audioUrl     String?
  videoUrl     String?
  runpodJobId  String?
  status       String      @default("PENDING")
  errorMessage String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  avatarId     String?
  avatar       UserAvatar? @relation(fields: [avatarId], references: [id])
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([avatarId])
}

model UserAvatar {
  id            String        @id @default(cuid())
  userId        String
  name          String
  imageUrl      String
  voiceAudioUrl String?
  voiceId       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  avatarVideos  AvatarVideo[]
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum Role {
  USER
  ADMIN
}

enum Status {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ChannelType {
  AVATAR
  DARK_CHANNEL
}

enum Platform {
  YOUTUBE
  TIKTOK
  INSTAGRAM
  LINKEDIN
  YOUTUBE_SHORTS
}

enum TopicStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  FAILED
  PROCESSING
}

enum PostStatus {
  DRAFT
  QUEUED
  GENERATING
  READY
  PUBLISHED
  FAILED
}
